{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/install", "destination": "/install.md" }
  ],
  "headers": [
    {
      "source": "/install(\\.md)?",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Content-Disposition", "value": "inline" }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [{ "key": "Content-Type", "value": "text/plain; charset=utf-8" }]
    }
  ]
}
